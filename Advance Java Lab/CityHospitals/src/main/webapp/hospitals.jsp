<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <title>Top 5 Hospitals & Tourist Places</title>
    <style>
        body {
            font-family: Arial;
            background: #f4f4f4;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #222;
        }
        .card {
            background: white;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        h2 {
            color: #0056A3;
        }
    </style>
</head>
<body>

<h1>Top 5 Hospitals in My City</h1>

<div class="card">
    <h2>1. City Medical Hospital</h2>
    <ul>
        <li>24x7 Emergency</li>
        <li>Heart & Neuro Care</li>
    </ul>
</div>

<div class="card">
    <h2>2. Global Super Speciality Hospital</h2>
    <ul>
        <li>Advanced ICU</li>
        <li>Modern Labs</li>
    </ul>
</div>

<div class="card">
    <h2>3. Metro Care Hospital</h2>
    <ul>
        <li>Experienced Doctors</li>
        <li>24x7 Pharmacy</li>
    </ul>
</div>

<div class="card">
    <h2>4. LifeLine Hospital</h2>
    <ul>
        <li>Affordable Treatment</li>
        <li>Diagnostic Center</li>
    </ul>
</div>

<div class="card">
    <h2>5. Trust General Hospital</h2>
    <ul>
        <li>Specialized Surgery Unit</li>
        <li>Emergency Care</li>
    </ul>
</div>

<h1>Famous Tourist Places in My City</h1>

<div class="card">
    <h2>1. City Park</h2>
    <p>Beautiful picnic and walking area.</p>
</div>

<div class="card">
    <h2>2. Heritage Fort</h2>
    <p>Popular historic monument.</p>
</div>

<div class="card">
    <h2>3. Riverfront</h2>
    <p>Peaceful evening spot.</p>
</div>

<div class="card">
    <h2>4. City Museum</h2>
    <p>Traditional & cultural exhibits.</p>
</div>

<div class="card">
    <h2>5. Mega Mall</h2>
    <p>Shopping + entertainment hub.</p>
</div>

</body>
</html>